# API
EXPO_PUBLIC_API_URL=http://localhost:3000

# Feature flags
EXPO_PUBLIC_RATED_TOURNAMENT_ENABLED=false

# Auto-confirm window (must match AUTO_CONFIRM_WINDOW_MINUTES on the server)
EXPO_PUBLIC_AUTO_CONFIRM_WINDOW_MINUTES=1440

# Sentry (get DSN from sentry.io after creating a React Native project)
EXPO_PUBLIC_SENTRY_DSN=
