{
  "name": "billiard-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "web": "expo start --web",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "ios": "expo run:ios --device \"iPhone 17 Pro\"",
    "ios:small": "expo run:ios --device \"iPhone SE (3rd generation)\"",
    "ios:base": "expo run:ios --device \"iPhone 15\"",
    "ios:large": "expo run:ios --device \"iPhone 15 Pro Max\"",
    "ios:ipad": "expo run:ios --device \"iPad Pro 11-inch (M4)\"",
    "ios:ipad:large": "expo run:ios --device \"iPad Pro 13-inch (M4)\""
  },
  "dependencies": {
    "@expo-google-fonts/barlow": "^0.4.1",
    "@expo-google-fonts/oswald": "^0.4.2",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-picker/picker": "2.11.4",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "@sentry/react-native": "~7.11.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@types/jest": "29.5.14",
    "babel-preset-expo": "~55.0.8",
    "expo": "^55.0.0",
    "expo-font": "~55.0.4",
    "expo-image": "~55.0.6",
    "expo-linear-gradient": "~55.0.9",
    "expo-secure-store": "~55.0.9",
    "expo-splash-screen": "~55.0.12",
    "expo-status-bar": "~55.0.4",
    "i18next": "^25.8.14",
    "react": "19.2.0",
    "react-i18next": "^16.5.6",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.10",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.11",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterFramework": [
      "@testing-library/react-native/matchers"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/test/setup.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ]
  },
  "private": true
}
